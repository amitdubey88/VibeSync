# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/vibesync

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:5173

# File Upload (local dev fallback — used when Cloudinary is NOT configured)
MAX_FILE_SIZE_MB=500

# ── Cloudinary (required in production for video uploads) ─────────────────────
# Get these from: https://cloudinary.com → Dashboard → API Keys
# Leave blank in local dev to use local disk storage instead.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
