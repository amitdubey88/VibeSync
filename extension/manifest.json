{
  "manifest_version": 3,
  "name": "VibeSync — Watch Together",
  "version": "1.0.0",
  "description": "Sync Netflix, Amazon Prime, Hotstar, JioCinema & more with friends in your VibeSync room.",
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "tabs", "scripting", "activeTab"],
  "host_permissions": [
    "*://*.netflix.com/*",
    "*://*.primevideo.com/*",
    "*://*.hotstar.com/*",
    "*://*.jiocinema.com/*",
    "*://*.disneyplus.com/*",
    "*://*.max.com/*",
    "*://*.hbomax.com/*",
    "*://*.tv.apple.com/*",
    "*://*.sonyliv.com/*",
    "*://*.zee5.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.netflix.com/watch/*",
        "*://*.primevideo.com/detail/*",
        "*://*.primevideo.com/region/*",
        "*://*.hotstar.com/*",
        "*://*.jiocinema.com/*",
        "*://*.disneyplus.com/*",
        "*://*.max.com/*",
        "*://*.sonyliv.com/*",
        "*://*.zee5.com/*"
      ],
      "js": ["src/content_script.js"],
      "css": ["src/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "VibeSync",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["src/injected.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
